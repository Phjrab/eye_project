# Hardware selector: jetson | rpi
MODEL_DEVICE=jetson

# RPi ONNX model paths (used when MODEL_DEVICE=rpi)
YOLO_ONNX_PATH=models/yolo.onnx
CLASSIFIER_ONNX_PATH=models/efficientnet.onnx

# Server config
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG_MODE=0
SESSION_COOKIE_SECURE=0
EYE_APP_SECRET_KEY=

# Admin auth (required for /api/admin/login)
ADMIN_LOGIN_NAME=admin
ADMIN_LOGIN_PASSWORD=
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=300
ADMIN_LOGIN_LOCK_SECONDS=300

# Camera / thresholds (optional overrides for config.py)
CAMERA_DEVICE_INDEX=0
YOLO_CONF_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
YOLO_STATUS_CONF_THRESHOLD=0.25
YOLO_INPUT_SIZE=640
CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
IRIS_REMOVAL_ENABLED=1
IRIS_THRESHOLD=0.3
AUTO_DIST_THRESHOLD=30
AUTO_SCALE_MIN=0.8
AUTO_SCALE_MAX=1.1
AUTO_CAPTURE_HOLD_FRAMES=10

# LLM chat config (for /api/chat)
# Supported providers: openai | gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
